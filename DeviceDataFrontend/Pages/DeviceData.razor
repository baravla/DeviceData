@page "/device-data"
@using DeviceDataModels
@using DeviceDataFrontend
@inject HttpClient Http

<h2 class="mb-4">Device Data Management</h2>

<div class="row">

    <!-- ADD CARD -->
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                Add Device Packet
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label">Patient Id</label>
                    <input @bind="newPacket.PatientId" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Source</label>
                    <input @bind="newPacket.Source" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Timestamp</label>
                    <input type="datetime-local" @bind="timestampInput" class="form-control" />
                </div>

                <hr />

                <h6>Add Parameter</h6>

                <div class="row g-2 mb-2">
                <div class="col">
                        <select @bind="newParamName" class="form-select">
                            @foreach (var opt in parameterOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </div>
                    <div class="col">
                        <input type="number" step="0.1" placeholder="Value" @bind="newParamValue" class="form-control" />
                    </div>
                </div>

                <button class="btn btn-outline-secondary btn-sm mb-3 w-100" @onclick="AddParameter">
                    + Add Parameter
                </button>

                @if (newPacket.Parameters.Any())
                {
                    <ul class="list-group mb-3">
                        @foreach (var p in newPacket.Parameters) {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@p.Name</span>
                                <strong>@p.Value</strong>
                            </li>
                        }
                    </ul>
                }

                <button class="btn btn-success w-100" @onclick="AddPacket">
                    Add Packet
                </button>

            </div>
        </div>

        @if (!string.IsNullOrEmpty(addErrorMessage))
        {
            <div class="alert alert-danger">
                @addErrorMessage
            </div>
        }
    </div>



    <!-- SEARCH CARD -->
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                Search
            </div>
            <div class="card-body">

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient Id</label>
                        <input @bind="filterPatientId" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Source</label>
                        <input @bind="filterSource" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">From</label>
                        <input type="datetime-local" @bind="filterFrom" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">To</label>
                        <input type="datetime-local" @bind="filterTo" class="form-control" />
                    </div>
                    
                    <div class="col-12">
                        <label class="form-label">Parameter filters (optional)</label>
                        <div class="list-group mb-2">
                            @for (int i = 0; i < filterParameterFilters.Count; i++) {
                                var idx = i;
                                <div class="row g-2 mb-2 align-items-center">
                                    <div class="col-md-5">
                                        <select class="form-select" @bind="filterParameterFilters[idx].Name">
                                            @foreach (var opt in parameterOptions) {
                                                <option value="@opt">@opt</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <input type="number" step="0.1" class="form-control" placeholder="Min" @bind="filterParameterFilters[idx].Min" />
                                    </div>
                                    <div class="col-md-3">
                                        <input type="number" step="0.1" class="form-control" placeholder="Max" @bind="filterParameterFilters[idx].Max" />
                                    </div>
                                    <div class="col-md-1">
                                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="(() => RemoveParameterFilter(idx))">&times;</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddParameterFilter">+ Add parameter filter</button>
                    </div>
                </div>

                <button class="btn btn-primary w-100" @onclick="LoadData">
                    Search
                </button>

            </div>
        </div>

        <!-- RESULTS -->
        @if (results == null)
        {
            <div class="text-muted">No search performed yet.</div>
        }
        else if (!results.Any())
        {
            <div class="alert alert-warning">No data found.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Patient</th>
                                    <th>Source</th>
                                    <th>Timestamp</th>
                                    <th>Parameters</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in results)
                                {
                                    <tr>
                                        <td>@item.PatientId</td>
                                        <td>@item.Source</td>
                                        <td>@item.Timestamp</td>
                                        <td>
                                            @foreach (var p in item.Parameters)
                                            {
                                                <span class="badge bg-secondary me-1">@p.Name: @p.Value</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(searchErrorMessage)) {
            <div class="alert alert-danger mb-3">
                @searchErrorMessage
            </div>
        }
    </div>

</div>

@code {

    private const string pathApiRoute = "api/DeviceData";
    // =====================
    // ADD SECTION
    // =====================
    private DevicePacket newPacket = new();
    private DateTime timestampInput = DateTime.Now;

    private string[] parameterOptions = new[] { "Heart Rate", "Respiratory Rate", "Temperature (F)" };
    private string newParamName = "Heart Rate";
    private double newParamValue;

    // Сообщение об ошибке при добавлении
    private string? addErrorMessage;

    private void AddParameter() {
        if (!string.IsNullOrWhiteSpace(newParamName)) {
            newPacket.Parameters.Add(new DeviceParameter {
                Name = newParamName,
                Value = newParamValue
            });

            newParamName = parameterOptions.Length > 0 ? parameterOptions[0] : string.Empty;
            newParamValue = 0;
        }
    }

    private void AddParameterFilter()
    {
        filterParameterFilters.Add(new ParameterFilterModel { Name = parameterOptions.Length > 0 ? parameterOptions[0] : string.Empty });
    }

    private void RemoveParameterFilter(int index)
    {
        if (index >= 0 && index < filterParameterFilters.Count)
            filterParameterFilters.RemoveAt(index);
    }

    private async Task AddPacket() {
        addErrorMessage = null; // Сбрасываем предыдущее сообщение
        newPacket.Timestamp = timestampInput;
        // Client-side validation
        if (string.IsNullOrWhiteSpace(newPacket.PatientId)) {
            addErrorMessage = "PatientId is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newPacket.Source)) {
            addErrorMessage = "Source is required.";
            return;
        }

        try {
            var response = await Http.PostAsJsonAsync(pathApiRoute, newPacket);

            if (response.IsSuccessStatusCode) {
                newPacket = new DevicePacket();
            }
            else {
                var text = await response.Content.ReadAsStringAsync();
                addErrorMessage = $"Server returned error: {response.StatusCode} - {text}";
            }
        }
        catch (Exception ex) {
            addErrorMessage = $"Error: {ex.Message}";
        }
    }

    // =====================
    // SEARCH SECTION
    // =====================
    private string? filterPatientId;
    private string? filterSource;
    private DateTime? filterFrom;
    private DateTime? filterTo;
    private class ParameterFilterModel {
        public string Name { get; set; } = string.Empty;
        // Keep as string to avoid Blazor number parsing errors while typing.
        public string? Min { get; set; }
        public string? Max { get; set; }
    }

    private List<ParameterFilterModel> filterParameterFilters = new();

    private List<DevicePacket>? results;

    // Сообщение об ошибке при поиске
    private string? searchErrorMessage;

    private async Task LoadData() {
        searchErrorMessage = null; // Сбрасываем предыдущее сообщение
        results = null;

        if (filterFrom.HasValue && filterTo.HasValue && filterFrom > filterTo) {
            searchErrorMessage = "'From' must be less than or equal to 'To'.";
            return;
        }

        // Validate parameter filters (min <= max) and parse values lazily
        for (int i = 0; i < filterParameterFilters.Count; i++) {
            var pf = filterParameterFilters[i];
            if (!string.IsNullOrWhiteSpace(pf.Name)) {
                if (!string.IsNullOrWhiteSpace(pf.Min) && !string.IsNullOrWhiteSpace(pf.Max)) {
                    if (!double.TryParse(pf.Min, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var minVal)) {
                        searchErrorMessage = $"Parameter filter #{i + 1}: Min is not a valid number.";
                        return;
                    }
                    if (!double.TryParse(pf.Max, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var maxVal)) {
                        searchErrorMessage = $"Parameter filter #{i + 1}: Max is not a valid number.";
                        return;
                    }
                    if (minVal > maxVal) {
                        searchErrorMessage = $"Parameter filter #{i + 1}: Min must be <= Max.";
                        return;
                    }
                }
            }
        }

        var query = new List<string>();

        if (!string.IsNullOrWhiteSpace(filterPatientId))
            query.Add($"patientId={Uri.EscapeDataString(filterPatientId)}");

        if (!string.IsNullOrWhiteSpace(filterSource))
            query.Add($"source={Uri.EscapeDataString(filterSource)}");

        if (filterFrom.HasValue)
            query.Add($"from={filterFrom.Value:o}");

        if (filterTo.HasValue)
            query.Add($"to={filterTo.Value:o}");

        var url = pathApiRoute;

        // Add parameter filters (can be empty). Parse Min/Max as needed using invariant culture.
        foreach (var pf in filterParameterFilters)
        {
            if (!string.IsNullOrWhiteSpace(pf.Name))
            {
                query.Add($"parameterName={Uri.EscapeDataString(pf.Name)}");

                if (!string.IsNullOrWhiteSpace(pf.Min) && double.TryParse(pf.Min, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var minVal))
                    query.Add($"minValue={minVal.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

                if (!string.IsNullOrWhiteSpace(pf.Max) && double.TryParse(pf.Max, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var maxVal))
                    query.Add($"maxValue={maxVal.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
            }
        }

        if (query.Any())
            url += "?" + string.Join("&", query);

        try {
            results = await Http.GetFromJsonAsync<List<DevicePacket>>(url);
        }
        catch (Exception ex) {
            searchErrorMessage = $"Error: {ex.Message}";
        }
    }
}