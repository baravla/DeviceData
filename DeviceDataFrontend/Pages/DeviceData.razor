@page "/device-data"
@using DeviceDataModels
@inject HttpClient Http

<h2 class="mb-4">Device Data Management</h2>

<div class="row">

    <!-- ADD CARD -->
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                Add Device Packet
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label">Patient Id</label>
                    <input @bind="newPacket.PatientId" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Source</label>
                    <input @bind="newPacket.Source" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Timestamp</label>
                    <input type="datetime-local" @bind="timestampInput" class="form-control" />
                </div>

                <hr />

                <h6>Add Parameter</h6>

                <div class="row g-2 mb-2">
                    <div class="col">
                        <input placeholder="Name" @bind="newParamName" class="form-control" />
                    </div>
                    <div class="col">
                        <input type="number" step="0.1" placeholder="Value" @bind="newParamValue" class="form-control" />
                    </div>
                </div>

                <button class="btn btn-outline-secondary btn-sm mb-3 w-100" @onclick="AddParameter">
                    + Add Parameter
                </button>

                @if (newPacket.Parameters.Any())
                {
                    <ul class="list-group mb-3">
                        @foreach (var p in newPacket.Parameters) {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@p.Name</span>
                                <strong>@p.Value</strong>
                            </li>
                        }
                    </ul>
                }

                <button class="btn btn-success w-100" @onclick="AddPacket">
                    Add Packet
                </button>

            </div>
        </div>

        @if (!string.IsNullOrEmpty(addErrorMessage))
        {
            <div class="alert alert-danger">
                @addErrorMessage
            </div>
        }
    </div>



    <!-- SEARCH CARD -->
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                Search
            </div>
            <div class="card-body">

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient Id</label>
                        <input @bind="filterPatientId" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Source</label>
                        <input @bind="filterSource" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">From</label>
                        <input type="datetime-local" @bind="filterFrom" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">To</label>
                        <input type="datetime-local" @bind="filterTo" class="form-control" />
                    </div>
                </div>

                <button class="btn btn-primary w-100" @onclick="LoadData">
                    Search
                </button>

            </div>
        </div>

        <!-- RESULTS -->
        @if (results == null)
        {
            <div class="text-muted">No search performed yet.</div>
        }
        else if (!results.Any())
        {
            <div class="alert alert-warning">No data found.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Patient</th>
                                    <th>Source</th>
                                    <th>Timestamp</th>
                                    <th>Parameters</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in results)
                                {
                                    <tr>
                                        <td>@item.PatientId</td>
                                        <td>@item.Source</td>
                                        <td>@item.Timestamp</td>
                                        <td>
                                            @foreach (var p in item.Parameters)
                                            {
                                                <span class="badge bg-secondary me-1">@p.Name: @p.Value</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(searchErrorMessage)) {
            <div class="alert alert-danger mb-3">
                @searchErrorMessage
            </div>
        }
    </div>

</div>

@code {
    // =====================
    // ADD SECTION
    // =====================
    private DevicePacket newPacket = new();
    private DateTime timestampInput = DateTime.Now;

    private string? newParamName;
    private double newParamValue;

    // Сообщение об ошибке при добавлении
    private string? addErrorMessage;

    private void AddParameter() {
        if (!string.IsNullOrWhiteSpace(newParamName)) {
            newPacket.Parameters.Add(new DeviceParameter {
                Name = newParamName,
                Value = newParamValue
            });

            newParamName = string.Empty;
            newParamValue = 0;
        }
    }

    private async Task AddPacket() {
        addErrorMessage = null; // Сбрасываем предыдущее сообщение
        newPacket.Timestamp = timestampInput;

        try {
            var response = await Http.PostAsJsonAsync("api/devicedata", newPacket);

            if (response.IsSuccessStatusCode) {
                newPacket = new DevicePacket();
            }
            else {
                addErrorMessage = $"Server returned error: {response.StatusCode}";
            }
        }
        catch (Exception ex) {
            addErrorMessage = $"Error: {ex.Message}";
        }
    }

    // =====================
    // SEARCH SECTION
    // =====================
    private string? filterPatientId;
    private string? filterSource;
    private DateTime? filterFrom;
    private DateTime? filterTo;

    private List<DevicePacket>? results;

    // Сообщение об ошибке при поиске
    private string? searchErrorMessage;

    private async Task LoadData() {
        searchErrorMessage = null; // Сбрасываем предыдущее сообщение
        results = null;

        var query = new List<string>();

        if (!string.IsNullOrWhiteSpace(filterPatientId))
            query.Add($"patientId={filterPatientId}");

        if (!string.IsNullOrWhiteSpace(filterSource))
            query.Add($"source={filterSource}");

        if (filterFrom.HasValue)
            query.Add($"from={filterFrom.Value:o}");

        if (filterTo.HasValue)
            query.Add($"to={filterTo.Value:o}");

        var url = "api/devicedata";

        if (query.Any())
            url += "?" + string.Join("&", query);

        try {
            results = await Http.GetFromJsonAsync<List<DevicePacket>>(url);
        }
        catch (Exception ex) {
            searchErrorMessage = $"Error: {ex.Message}";
        }
    }
}